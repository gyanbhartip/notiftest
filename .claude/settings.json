{
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Edit|Write|Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/backend/.venv/bin/code-review-graph update --skip-flows",
                        "timeout": 30
                    }
                ]
            }
        ],
        "SessionStart": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/backend/.venv/bin/code-review-graph status",
                        "timeout": 10
                    }
                ]
            }
        ]
    }
}
